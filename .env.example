DEVICE0=""
MEASUREMENT_INTERVAL_SEC=300

# --- automation(エアコン自動OFF)---
# SwitchBot API 認証(アプリ → プロフィール → 設定 → 開発者向けオプション)
SWITCHBOT_TOKEN=""
SWITCHBOT_SECRET=""
# エアコンの deviceId(python -m automation.switchbot devices で確認)
SWITCHBOT_AIRCON_DEVICE_ID=""
# 人感センサーの GPIO 番号(未設定なら人感監視オフ=自動OFFは発動しない)
PIR_GPIO=""
# false にすると実際に OFF を送信する(デフォルトはドライラン)
AUTOMATION_DRY_RUN=true
